<head>
  <meta charset="utf-8">
  <%
  var title = [];
  if (page.current > 1) title.push(__('page', page.current));
  if (page.title) title.push(page.title);
  if (page.category) title.push(page.category);
  if (page.tag) title.push(page.tag);
  if (page.archive){
    if (page.year) title.push(__('archive_b', page.year + (page.month ? '/' + page.month : '')));
    else title.push(__('archive_a'));
  }
  if (!title.length && config.subtitle) title.push(config.subtitle);
  title.push(config.title);
  var resolvedTitle = title.join(' | ');
  var metaDescription = '';
  if (page.description) metaDescription = page.description;
  else if (config.description) metaDescription = config.description;
  else if (page.excerpt) metaDescription = strip_html(page.excerpt);
  else if (page.content) metaDescription = strip_html(page.content).substring(0, 150);
  metaDescription = metaDescription ? metaDescription.replace(/\s+/g, ' ').trim() : '';
  var canonicalUrl = page.permalink || (config.url + url_for(page.path || ''));
  canonicalUrl = canonicalUrl.replace(/index\.html$/, '');
  var ogType = page.layout === 'post' ? 'article' : 'website';
  var ogImage = config.cover || '';
  if (page.cover) {
    if (page.cover.match(/^https?:\/\//)) ogImage = page.cover;
    else if (page.cover.match(/^\//)) ogImage = config.url + page.cover;
    else ogImage = page.permalink + page.cover;
  } else if (page.layout === 'post') {
    ogImage = page.permalink + 'cover.jpg';
  }
  %>
  <title><%= resolvedTitle %></title>
  <% if (config.author){ %><meta name="author" content="<%= config.author %>"><% } %>
  <% if (metaDescription){ %><meta name="description" content="<%= metaDescription %>"><% } %>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <link rel="canonical" href="<%= canonicalUrl %>">

  <meta property="og:title" content="<%= page.title || resolvedTitle %>"/>
  <% if (metaDescription){ %><meta property="og:description" content="<%= metaDescription %>"/><% } %>
  <meta property="og:site_name" content="<%= config.title %>"/>
  <meta property="og:type" content="<%= ogType %>"/>
  <meta property="og:url" content="<%= canonicalUrl %>"/>
  <% if (ogImage){ %><meta property="og:image" content="<%= ogImage %>" /><% } %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= page.title || resolvedTitle %>">
  <% if (metaDescription){ %><meta name="twitter:description" content="<%= metaDescription %>"><% } %>
  <% if (ogImage){ %><meta name="twitter:image" content="<%= ogImage %>"><% } %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet">

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3389697259947664"
      crossorigin="anonymous"></script>

  <%- favicon_tag('favicon.png') %>
  <% if (config.feed) { %>
    <%- feed_tag() %>
  <% } else if (theme.rss) { %>
    <%- feed_tag(theme.rss) %>
  <% } %>
  <%- css('css/style.css?v=260618') %>
  <!--[if lt IE 9]><script src="https://cdn.jsdelivr.net/npm/html5shiv@3.7.3/dist/html5shiv.min.js"></script><![endif]-->
  <%- partial('google_analytics') %>
</head>
