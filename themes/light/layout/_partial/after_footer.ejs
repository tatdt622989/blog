<script defer src="<%- url_for('js/custom.js?v=260623-1') %>"></script>

<% if (page.layout === 'post'){ %>
<script defer src="<%- url_for('js/jquery-3.4.1.min.js') %>"></script>
<script defer src="<%- url_for('js/jquery.imagesloaded.min.js') %>"></script>
<script defer src="<%- url_for('js/gallery.js?v=260526-1') %>"></script>
<% } %>

<% if (config.disqus_shortname){ %>
<script>
var disqus_shortname = '<%= config.disqus_shortname %>';

(function(){
  var dsq = document.createElement('script');
  dsq.type = 'text/javascript';
  dsq.async = true;
  dsq.src = 'https://' + disqus_shortname + '.disqus.com/<% if (page.comments){ %>embed.js<% } else { %>count.js<% } %>';
  (document.getElementsByTagName('head')[0] || document.getElementsByTagName('body')[0]).appendChild(dsq);
}());
</script>
<% } %>

<% if (theme.fancybox && page.layout === 'post'){ %>
<%- css('fancybox/jquery.fancybox.css') %>
<script defer src="<%- url_for('fancybox/jquery.fancybox.pack.js') %>"></script>
<script>
window.addEventListener('DOMContentLoaded', function(){
  if (window.jQuery && jQuery.fn.fancybox) {
    jQuery('.fancybox').fancybox();
  }
});
</script>
<% } %>
